{
  "name": "final-project",
  "version": "0.2.3",
  "private": true,
  "scripts": {
    "postinstall": "cd backend && bun i",
    "dev": "concurrently \"bun --bun run dev:frontend\" \"bun --bun run dev:backend\"",
    "dev:frontend": "bun --bun next dev --turbopack",
    "dev:backend": "cd backend && bun dev",
    "start": "NODE_ENV=production concurrently \"bun --bun run start:frontend\" \"bun --bun run start:backend\"",
    "start:frontend": "bun --bun next start",
    "start:backend": "cd backend && bun start",
    "build": "bun --bun next build",
    "lint": "eslint"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "@libsql/client": "^0.17.3",
    "@tanstack/react-table": "^8.21.3",
    "@upyo/core": "^0.4.0",
    "@upyo/smtp": "^0.4.0",
    "ansi-styles": "^6.2.3",
    "arktype": "^2.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.2.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "ethiopian-calendar-date-converter": "^2.1.6",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.16.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "pg": "^8.21.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.76.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.1",
    "recharts": "2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bun": "^1.3.14",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.6",
    "shadcn": "^4.8.0",
    "swagger-ui-dist": "^5.32.6",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver",
    "better-sqlite3"
  ]
}
